<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="clr-namespace:FluentAvalonia.Styling;assembly=FluentAvalonia"
             x:Class="ImmersingLinker.UI.App"
             xmlns:local="using:ImmersingLinker.UI"
             RequestedThemeVariant="Default">

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Styles>
        <fa:FluentAvaloniaTheme />
    </Application.Styles>

    <TrayIcon.Icons>
        <TrayIcons>
            <TrayIcon ToolTipText="ImmersingLinker">
                <TrayIcon.Menu>
                    <NativeMenu>
                        <NativeMenuItem Header="学生看板"/>
                        <NativeMenuItem Header="编辑"/>
                        <NativeMenuItem Header="设置"/>
                        <NativeMenuItem Header="关于软件"/>
                        <NativeMenuItemSeparator/>
                        <NativeMenuItem Header="重新启动"/>
                        <NativeMenuItem Header="退出"/>
                    </NativeMenu>
                </TrayIcon.Menu>
            </TrayIcon>
        </TrayIcons>
    </TrayIcon.Icons>
</Application>
