<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ImmersingLinker.UI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="ImmersingLinker.UI.Views.LaunchWindow"
        x:DataType="vm:LaunchWindowViewModel"
        WindowDecorations="None"
        Width="800" Height="450"
        Title="ImmersingLinkerLauncher"
        RequestedThemeVariant="Dark">
    <Design.DataContext>
        <vm:LaunchWindowViewModel/>
    </Design.DataContext>
    <Window.Background>
        <ImageBrush Source="/Assets/LaunchWindowBackground.png"
                    Stretch="UniformToFill"/>
    </Window.Background>
    <Grid RowDefinitions="*,Auto,Auto,Auto" RowSpacing="8" Margin="16">
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="16">
            <TextBlock Text="ImmersingLinker" FontSize="40" FontWeight="Bold"/>
            <Border Background="#FF9800" Height="24" CornerRadius="12">
                <TextBlock Text="0.0.0.0" Margin="8 0 8 0" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </StackPanel>
        <TextBlock Grid.Row="2" Text="{Binding StatusText}" FontSize="24" FontWeight="Regular"/>
        <ProgressBar Grid.Row="3" IsIndeterminate="True"/>
    </Grid>
</Window>
